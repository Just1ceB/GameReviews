@page "/SIGNEDIN/{logInEmail}&{logInPass}${logInID}"

@using MySql.Data.MySqlClient;

<PageTitle>Games Reviews - Options panel</PageTitle>

<style>
    /* עיצוב רקע הדף */
    body {
        background-color: #f4f7f6;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        margin: 0;
        color: #333;
    }

    /* תיבת העריכה */
    .change-container {
        background: #ffffff;
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        width: 100%;
        max-width: 400px;
        text-align: center;
        border: 1px solid #e0e0e0;
    }

    h2 {
        margin-bottom: 10px;
        color: #2c3e50;
        font-weight: 600;
    }

    .subtitle {
        color: #7f8c8d;
        font-size: 0.9rem;
        margin-bottom: 25px;
    }

    /* כפתור CHANGE DATA - ירוק */
    .btn-change {
        background-color: #2ecc71;
        color: white;
    }

    /* עיצוב כללי לכפתורי הניווט */
    .menu-button {
        display: block;
        width: 100%;
        padding: 15px;
        margin: 12px 0;
        text-decoration: none;
        font-size: 16px;
        font-weight: 600;
        border-radius: 10px;
        transition: all 0.3s ease;
        box-sizing: border-box;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        /* אפקט ריחף כללי */
        .menu-button:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        }
    /* כפתור SIGN UP - כחול */
    .btn-signup {
        background-color: #3498db;
        color: white;
    }

        .btn-signup:hover {
            background-color: #2980b9;
        }

    /* כפתור CHANGE DATA - ירוק */
    .btn-change {
        background-color: #2ecc71;
        color: white;
    }

        .btn-change:hover {
            background-color: #27ae60;
        }

    /* כפתור DELETE USER - אדום */
    .btn-delete {
        background-color: #e74c3c;
        color: white;
    }

        .btn-delete:hover {
            background-color: #c0392b;
        }

    /* עיצוב הכפתור */
    button {
        width: 100%;
        background-color: #2ecc71;
        color: white;
        padding: 14px;
        margin-top: 20px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 16px;
        font-weight: 600;
        letter-spacing: 0.5px;
        transition: background-color 0.3s ease;
    }

        button:hover {
            background-color: #27ae60;
        }

    /* עיצוב הקישור למטה */
    .back-link {
        display: block;
        margin-top: 20px;
        color: #3498db;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
    }

        .back-link:hover {
            text-decoration: underline;
        }

    /* הודעת הסבר קטנה */
    .info-text {
        background-color: #e8f5e9;
        color: #2e7d32;
        padding: 10px;
        border-radius: 6px;
        font-size: 0.85rem;
        margin-bottom: 15px;
    }

</style>

<div class="change-container">
    @if (name != null)
    {
        <h2>Hello @name</h2>
        <p class="subtitle">Please choose what you want to do</p>

        <NavLink href="@($"/DATACHANGE/{logInEmail}&{logInPass}${logInID}")" class="menu-button btn-signup">Change data </NavLink>
        <NavLink href="@($"/ADDREVIEW/{logInEmail}&{logInPass}${logInID}")" class="menu-button btn-change">Add review</NavLink>
        <NavLink href="@($"/DELETE/{logInEmail}&{logInPass}${logInID}")" class="menu-button btn-delete">Delete user</NavLink>

        <a href="/" class="back-link">logout</a>
    }
    else
    {
        <h1>ERROR: USER DOESN'T EXIST</h1>
        <a href="/" class="back-link">To Homepage</a>
    }
</div>

@code
{
    MySqlConnection sqlCon = new MySqlConnection();
    MySqlCommand cmd = new MySqlCommand();
    MySqlDataReader reader;

    string name;

    [Parameter] public string logInEmail { get; set; }
    [Parameter] public string logInPass { get; set; }
    [Parameter] public string logInID { get; set; }

    protected override void OnInitialized()
    {
        sqlCon.ConnectionString = "server=localhost;user id=root;password=josh17rog;database=classproject;";
        cmd.Connection = sqlCon;
        sqlCon.Open();
        cmd.CommandText = $"SELECT * FROM `classproject`.`users` WHERE(`userID` = '{logInID}');";
        reader = cmd.ExecuteReader();
        while (reader.Read())
        {
            name = reader["userName"].ToString();
        }
        reader.Close();
        sqlCon.Close();
    }
    
}
