@page "/"

<PageTitle>SQL Manager - Dashboard</PageTitle>

<style>
    /* עיצוב רקע הדף */
    body {
        background-color: #f4f7f6;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        margin: 0;
        color: #333;
    }

    /* תיבת התפריט המרכזית */
    .menu-container {
        background: #ffffff;
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0 4px 25px rgba(0, 0, 0, 0.1);
        width: 100%;
        max-width: 400px;
        text-align: center;
        border: 1px solid #e0e0e0;
    }

    h2 {
        margin-bottom: 8px;
        color: #2c3e50;
        font-weight: 600;
    }

    .subtitle {
        color: #7f8c8d;
        font-size: 0.95rem;
        margin-bottom: 30px;
    }

    /* עיצוב כללי לכפתורי הניווט */
    .menu-button {
        display: block;
        width: 100%;
        padding: 15px;
        margin: 12px 0;
        text-decoration: none;
        font-size: 16px;
        font-weight: 600;
        border-radius: 10px;
        transition: all 0.3s ease;
        box-sizing: border-box;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        /* אפקט ריחף כללי */
        .menu-button:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        }

    /* כפתור SIGN UP - כחול */
    .btn-signup {
        background-color: #3498db;
        color: white;
    }

        .btn-signup:hover {
            background-color: #2980b9;
        }

    /* כפתור CHANGE DATA - ירוק */
    .btn-change {
        background-color: #2ecc71;
        color: white;
    }

        .btn-change:hover {
            background-color: #27ae60;
        }

    /* כפתור DELETE USER - אדום */
    .btn-delete {
        background-color: #e74c3c;
        color: white;
    }

        .btn-delete:hover {
            background-color: #c0392b;
        }

    /* כפתור VIEW DATA (החדש) - סגול */
    .btn-view {
        background-color: #9b59b6;
        color: white;
    }

        .btn-view:hover {
            background-color: #8e44ad;
        }
</style>

<div class="menu-container">
    <h2>Control Panel</h2>
    <p class="subtitle">Select an action to manage the database</p>

    <a href="/REGISTER" class="menu-button btn-signup">Sign Up</a>

    <a href="/DATACHANGE" class="menu-button btn-change">Change Data</a>

    <a href="/DELETE" class="menu-button btn-delete">Delete User</a>

    <a href="/USERSLIST" class="menu-button btn-view">View All Users</a>
</div>