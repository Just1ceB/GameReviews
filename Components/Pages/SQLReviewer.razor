@page "/ADDREVIEW/{logInEmail}&{logInPass}"
@using MySql.Data.MySqlClient;

<PageTitle>Games Reviews - Games list</PageTitle>

<style>
    /* עיצוב רקע הדף */
    body {
        background-color: #f4f7f6;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        display: flex;
        justify-content: center;
        align-items: center; /* שיניתי למרכז כדי שזה יישב בול באמצע */
        height: 100vh; /* גובה מסך מלא */
        margin: 0;
        padding: 0;
        color: #333;
        /* הפקודה שמעלימה את פס הגלילה */
        overflow: hidden;
    }

    /* מיכל הטבלה */
    .table-container {
        background: #ffffff;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        width: 90%;
        max-width: 900px;
        border: 1px solid #e0e0e0;
        /* אם הטבלה תהיה גדולה מדי, רק בתוכה יהיה גלגל קטן */
        max-height: 90vh;
        overflow-y: auto;
    }

    h2 {
        text-align: center;
        color: #2c3e50;
        margin-bottom: 20px;
        font-weight: 600;
    }
    
    .add-review-btn {
    background-color: #9b59b6;
    color: white;
    border: none;
    padding: 6px 12px;
    border-radius: 5px;
    cursor: pointer;
    font-size: 0.85rem;
    transition: background 0.3s;
    }

    .add-review-btn:hover {
        background-color: #8e44ad;
    }

    /* עיצוב הטבלה */
    .custom-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 20px;
    }

        .custom-table th {
            background-color: #f8f9fa;
            color: #7f8c8d;
            padding: 15px;
            border-bottom: 2px solid #eee;
            text-align: left;
            font-size: 0.85rem;
        }

        .custom-table td {
            padding: 12px 15px;
            border-bottom: 1px solid #f1f1f1;
            font-size: 0.95rem;
        }

        .custom-table tr:hover {
            background-color: #f9fbff;
        }

    .back-btn {
        display: inline-block;
        color: #9b59b6;
        text-decoration: none;
        font-weight: 500;
    }
</style>

<div class="table-container">
    @if (userAge > 13)
    {
        <h2>Games</h2>

        <table class="custom-table">
            <thead>
                <tr>
                    <th>ID: Title</th>
                    <th>Description</th>
                    <th>Release Date</th>
                    <th>Community Review</th>
                </tr>
            </thead>
            <tbody>
                @while (reader.Read())
                {
                    gameID = int.Parse(reader["gameID"].ToString()); 
                    title = reader["gameTitle"].ToString();
                    description = reader["gameSummary"].ToString();
                    releaseDate = reader["releaseDate"].ToString();
                    reviews = reader["gameReview"].ToString();

                    <tr>
                        <td><strong>#@gameID: @title</strong></td>
                        <td>@description</td>
                        <td>@releaseDate</td>
                        <td>
                            <div style="display: flex; gap: 10px; align-items: center;">
                                <span>@reviews</span>
                                <NavLink href="@($"/ADDREVIEWPANEL/{logInEmail}&{logInPass}&{gameID}")" class="add-review-btn">Rate</NavLink>
                            </div>
                        </td>
                    </tr>
                }
                @{
                    reader.Close();
                }
            </tbody>
        </table>
    }
    else
    {
        <h1> YOU ARE TOO YOUNG!</h1>
    }

    <NavLink href="@($"/SIGNEDIN/{logInEmail}&{logInPass}")" class="menu-button back-btn">back</NavLink>
</div>

@code {
    MySqlConnection sqlCon = new MySqlConnection();
    MySqlCommand cmd = new MySqlCommand();
    MySqlDataReader reader;
    string title;
    string description;
    string releaseDate;
    string reviews;
    int gameID;
    int revGameID; // ID of the game to review
    uint id;
    int userReview = 0;
    int userAge;


    [Parameter] public string logInEmail { get; set; }
    [Parameter] public string logInPass { get; set; }

    protected override void OnInitialized()
    {
        sqlCon.ConnectionString = "server=localhost;user id=root;password=josh17rog;database=classproject;";
        cmd.Connection = sqlCon;
        sqlCon.Open();

        cmd.CommandText = $"SELECT * FROM `classproject`.`users`;";
        reader = cmd.ExecuteReader();

        while (reader.Read())
        {
            userAge = DateTime.Now.Year - int.Parse(reader["birthYear"].ToString());
        }
        reader.Close();

        cmd.CommandText = $"SELECT * FROM `classproject`.`games`;";
        reader = cmd.ExecuteReader();
    }
}
