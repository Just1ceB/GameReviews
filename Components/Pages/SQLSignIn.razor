@page "/SIGNIN"
@using MySql.Data.MySqlClient;

<PageTitle>Games Reviews - Sign in</PageTitle>

<style>
    /* עיצוב רקע הדף */
    body {
        background-color: #f4f7f6;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        margin: 0;
        color: #333;
    }

    /* תיבת העריכה */
    .change-container {
        background: #ffffff;
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        width: 100%;
        max-width: 400px;
        text-align: center;
        border: 1px solid #e0e0e0;
    }

    h2 {
        margin-bottom: 10px;
        color: #2c3e50;
        font-weight: 600;
    }

    .subtitle {
        color: #7f8c8d;
        font-size: 0.9rem;
        margin-bottom: 25px;
    }

    /* עיצוב שדות הקלט */
    input {
        width: 100%;
        padding: 12px 15px;
        margin: 8px 0;
        display: inline-block;
        border: 1px solid #dcdde1;
        border-radius: 8px;
        box-sizing: border-box;
        background-color: #fafafa;
        color: #2f3640;
        font-size: 15px;
        transition: all 0.2s ease-in-out;
    }

        input:focus {
            border-color: #2ecc71; /* צבע ירוק במיקוד */
            background-color: #fff;
            outline: none;
            box-shadow: 0 0 5px rgba(46, 204, 113, 0.2);
        }


    /* עיצוב כללי לכפתורי הניווט */
    .menu-button {
        display: block;
        width: 100%;
        padding: 15px;
        margin: 12px 0;
        text-decoration: none;
        font-size: 16px;
        font-weight: 600;
        border-radius: 10px;
        transition: all 0.3s ease;
        box-sizing: border-box;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        /* אפקט ריחף כללי */
        .menu-button:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        }
    /* כפתור SIGN UP - כחול */
    .btn-signup {
        background-color: #3498db;
        color: white;
    }

        .btn-signup:hover {
            background-color: #2980b9;
        }

    /* עיצוב הכפתור */
    button {
        width: 100%;
        background-color: #2ecc71;
        color: white;
        padding: 14px;
        margin-top: 20px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 16px;
        font-weight: 600;
        letter-spacing: 0.5px;
        transition: background-color 0.3s ease;
    }

        button:hover {
            background-color: #27ae60;
        }

    /* עיצוב הקישור למטה */
    .back-link {
        display: block;
        margin-top: 20px;
        color: #3498db;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
    }

        .back-link:hover {
            text-decoration: underline;
        }

    /* הודעת הסבר קטנה */
    .info-text {
        background-color: #e8f5e9;
        color: #2e7d32;
        padding: 10px;
        border-radius: 6px;
        font-size: 0.85rem;
        margin-bottom: 15px;
    }
</style>

<div class="change-container">
    <h2>Sign in </h2>
    <p class="subtitle">Please enter your details to sign in</p>

    <input type="text" @bind="email" @onblur="UpdateDisplay" placeholder="Enter your email" />

    @if (email != null)
    {
        <input type="password" @bind="checkPassword" placeholder="Enter current password to unlock" />

        if (checkPassword == currentPassword && showButtons)
        {
            <div class="info-text">Email and Password Verified.</div>
            CypherData();
            <NavLink href="@($"/SIGNEDIN/{cypheredEmail}&{cypheredPass}${id}")" class="menu-button btn-signup">SIGN IN</NavLink>
        }
    }

    <a href="/" class="back-link">to homepage</a>
</div>

@code {
    MySqlConnection sqlCon = new MySqlConnection();
    MySqlCommand cmd = new MySqlCommand();
    MySqlDataReader reader;

    bool showButtons;
    string checkPassword, currentPassword;
    string name;
    string password;
    string email;
    int birthYear;
    uint id;
    string cypheredEmail;
    string cypheredPass;

    protected override void OnInitialized()
    {
        sqlCon.ConnectionString = "server=localhost;user id=root;password=josh17rog;database=classproject;";
        cmd.Connection = sqlCon;
        sqlCon.Open();
    }

    void UpdateDisplay()
    {
        cmd.CommandText = $"SELECT * FROM `classproject`.`users` WHERE(`userEmail` = '{email}');";
        reader = cmd.ExecuteReader();
        while (reader.Read())
        {
            name = reader["userName"].ToString();
            email = reader["userEmail"].ToString();
            id = uint.Parse(reader["userID"].ToString());
            currentPassword = reader["userPassword"].ToString();
            birthYear = int.Parse(reader["birthYear"].ToString());
            showButtons = true;
        }
        reader.Close();
        password = null;
    }

    void CypherData()
    {
        cypheredEmail = Cypher.ShiftCypher(email, birthYear);
        cypheredPass = Cypher.ShiftCypher(currentPassword, birthYear);
    }

}
