@page "/DATACHANGE/{logInEmail}&{logInPass}"
@using MySql.Data.MySqlClient;

<PageTitle>Games Reviews - Change info</PageTitle>

<style>
    /* עיצוב רקע הדף */
    body {
        background-color: #f4f7f6;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        margin: 0;
        color: #333;
    }

    /* תיבת העריכה */
    .change-container {
        background: #ffffff;
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        width: 100%;
        max-width: 400px;
        text-align: center;
        border: 1px solid #e0e0e0;
    }

    h2 {
        margin-bottom: 10px;
        color: #2c3e50;
        font-weight: 600;
    }

    .subtitle {
        color: #7f8c8d;
        font-size: 0.9rem;
        margin-bottom: 25px;
    }

    /* עיצוב שדות הקלט */
    input {
        width: 100%;
        padding: 12px 15px;
        margin: 8px 0;
        display: inline-block;
        border: 1px solid #dcdde1;
        border-radius: 8px;
        box-sizing: border-box;
        background-color: #fafafa;
        color: #2f3640;
        font-size: 15px;
        transition: all 0.2s ease-in-out;
    }

        input:focus {
            border-color: #2ecc71; /* צבע ירוק במיקוד */
            background-color: #fff;
            outline: none;
            box-shadow: 0 0 5px rgba(46, 204, 113, 0.2);
        }

    /* עיצוב הכפתור */
    button {
        width: 100%;
        background-color: #2ecc71;
        color: white;
        padding: 14px;
        margin-top: 20px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 16px;
        font-weight: 600;
        letter-spacing: 0.5px;
        transition: background-color 0.3s ease;
    }

        button:hover {
            background-color: #27ae60;
        }

    /* עיצוב הקישור למטה */
    .back-link {
        display: block;
        margin-top: 20px;
        color: #3498db;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
    }

    .subtitle {
        color: #7f8c8d;
        font-size: 0.9rem;
        margin-bottom: 25px;
    }

        .back-link:hover {
            text-decoration: underline;
        }

    /* הודעת הסבר קטנה */
    .info-text {
        background-color: #e8f5e9;
        color: #2e7d32;
        padding: 10px;
        border-radius: 6px;
        font-size: 0.85rem;
        margin-bottom: 15px;
    }
</style>

<div class="change-container">
    <h2>Change Data</h2>
    <p class="subtitle">@subtitle</p>

    <input type="text" @bind-value=@name placeholder="Your name" />
    <input type="text" @bind-value=@newEmail placeholder="Email Address" />
    <input type="number" @bind-value=@birthYear placeholder="Birth Year" />
    <input type="password" @bind-value=@password placeholder="New Password" />

    <button @onclick="ChangeData">UPDATE SETTINGS</button>
    
    <NavLink href="@($"/SIGNEDIN/{email}&{currentPassword}")" class="back-link">back</NavLink>
</div>

@code {
    MySqlConnection sqlCon = new MySqlConnection();
    MySqlCommand cmd = new MySqlCommand();
    MySqlDataReader reader;

    string currentPassword;
    string name;
    string password;
    string email;
    string subtitle = "Change your data";
    string newEmail;
    int birthYear;
    uint id;

    [Parameter] public string logInEmail { get; set; }
    [Parameter] public string logInPass { get; set; }

    protected override void OnInitialized()
    {
        sqlCon.ConnectionString = "server=localhost;user id=root;password=josh17rog;database=classproject;";
        cmd.Connection = sqlCon;
        sqlCon.Open();
        UpdateDisplay();
    }

    void UpdateDisplay()
    {
        MySqlDataReader reader;
        cmd.CommandText = $"SELECT * FROM `classproject`.`users` WHERE(`userEmail` = '{logInEmail}' AND `userPassword` = '{logInPass}');";
        reader = cmd.ExecuteReader();
        while (reader.Read())
        {
            name = reader["userName"].ToString();
            email = reader["userEmail"].ToString();
            id = uint.Parse(reader["userID"].ToString());
            currentPassword = reader["userPassword"].ToString();
            birthYear = int.Parse(reader["birthYear"].ToString());
        }
        reader.Close();
        newEmail = email;
        password = null;
    }

    bool IsEmailUnique()
    {
        cmd.CommandText = $"SELECT * FROM `classproject`.`users`;";
        reader = cmd.ExecuteReader();

        while (reader.Read())
        {
            if (reader["userEmail"].ToString() == email)
            {
                reader.Close();
                return false;
            }
        }

        reader.Close();
        return true;
    }

    void ChangeData()
    {
        if (IsEmailUnique() || newEmail == email)
        {
            ChangeName();
            ChangeEmail();
            ChangeBirthYear();
            if (password != null)
            {
                ChangePassword();
            }
            UpdateDisplay();
            subtitle = "Data changed!";
        }
        else
        {
            subtitle = "That email is already taken, sorry!";
        }
    }

    void ChangeName()
    {
        cmd.CommandText = $"UPDATE `classproject`.`users` SET `userName` = '{name}' WHERE (`userID` = '{id}');";
        cmd.ExecuteNonQuery();
    }

    void ChangeEmail()
    {
        cmd.CommandText = $"UPDATE `classproject`.`users` SET `userEmail` = '{newEmail}' WHERE (`userID` = '{id}');";
        cmd.ExecuteNonQuery();
    }

    void ChangeBirthYear()
    {
        cmd.CommandText = $"UPDATE `classproject`.`users` SET `birthYear` = '{birthYear}' WHERE (`userID` = '{id}');";
        cmd.ExecuteNonQuery();
    }

    void ChangePassword()
    {
        if (password != "")
        {
            cmd.CommandText = $"UPDATE `classproject`.`users` SET `userPassword` = '{password}' WHERE (`userID` = '{id}');";
            cmd.ExecuteNonQuery();
        }
    }
}
