@page "/REGISTER"
@using MySql.Data.MySqlClient;

<PageTitle>Games Reviews - Sign Up</PageTitle>

<style>
    /* עיצוב רקע הדף */
    body {
        background-color: #f4f7f6;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        margin: 0;
        color: #333;
    }

    /* תיבת ההרשמה הלבנה */
    .signup-container {
        background: #ffffff;
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        width: 100%;
        max-width: 380px;
        text-align: center;
        border: 1px solid #e0e0e0;
    }

    h2 {
        margin-bottom: 10px;
        color: #2c3e50;
        font-weight: 600;
    }

    p {
        color: #7f8c8d;
        font-size: 0.9rem;
        margin-bottom: 25px;
    }

    /* עיצוב שדות הקלט */
    input {
        width: 100%;
        padding: 12px 15px;
        margin: 8px 0;
        display: inline-block;
        border: 1px solid #dcdde1;
        border-radius: 8px;
        box-sizing: border-box;
        background-color: #fafafa;
        color: #2f3640;
        font-size: 15px;
        transition: all 0.2s ease-in-out;
    }

        /* אפקט כשלוחצים על שדה */
        input:focus {
            border-color: #3498db;
            background-color: #fff;
            outline: none;
            box-shadow: 0 0 5px rgba(52, 152, 219, 0.2);
        }

    /* עיצוב כללי לכפתורי הניווט */
    .menu-button {
        display: block;
        width: 100%;
        padding: 15px;
        margin: 12px 0;
        text-decoration: none;
        font-size: 16px;
        font-weight: 600;
        border-radius: 10px;
        transition: all 0.3s ease;
        box-sizing: border-box;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        /* אפקט ריחף כללי */
        .menu-button:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        }

    /* כפתור SIGN IN - ירוק */
    .btn-change {
        background-color: #2ecc71;
        color: white;
    }
        .btn-change:hover {
            background-color: #27ae60;
        }

    /* עיצוב הכפתור */
    button {
        width: 100%;
        background-color: #3498db;
        color: white;
        padding: 14px;
        margin-top: 20px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 16px;
        font-weight: 600;
        letter-spacing: 0.5px;
        transition: background-color 0.3s ease;
    }

        button:hover {
            background-color: #2980b9;
        }

        button:active {
            transform: translateY(1px);
        }

    /* הצגת תוצאה */
    .result-msg {
        margin-top: 15px;
        padding: 10px;
        border-radius: 6px;
        font-weight: bold;
        background-color: #C2D7F2;
        color: #4E9CF2;
    }

    /* עיצוב הקישור למטה */
    .back-link {
        display: block;
        margin-top: 20px;
        color: #3498db;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
    }

    .back-link:hover {
        text-decoration: underline;
    }
</style>

<div class="signup-container">
    @if (!registered)
    {
        <h2>Create an account</h2>
        <p>Please enter your details to register</p>

        <input type="text" @bind="name" placeholder="Full Name" />
        <input type="text" @bind="email" placeholder="Email Address" />
        <input type="text" @bind="birthYear" placeholder="Birth Year" />
        <input type="password" @bind="password" placeholder="Password" />
    
        <button @onclick="AddUser">SIGN UP</button> <br />

        if (title != null)
        {
            <div class="result-msg">@title</div>
        }
        <a href="/" class="back-link">I already have account</a>
    }
    else
    {
        <div class="result-msg">@title</div>
        <NavLink href="@($"/SIGNEDIN/{cypheredEmail}&{cypheredPass}${id}")" class="menu-button btn-change">SIGN IN</NavLink>
    }
</div>

@code {
    // הלוגיקה נשארה ללא שינוי בכלל
    MySqlConnection sqlCon = new MySqlConnection();
    MySqlCommand cmd = new MySqlCommand();
    MySqlDataReader reader;

    string title;
    string name;
    string password;
    string email;
    string birthYear;
    uint id;
    bool registered = false;

    string cypheredEmail;
    string cypheredPass;

    protected override void OnInitialized()
    {
        sqlCon.ConnectionString = "server=localhost;user id=root;password=josh17rog;database=classproject;";
        cmd.Connection = sqlCon;
        sqlCon.Open();
    }

    bool IsEmailUnique()
    {
        cmd.CommandText = $"SELECT * FROM `classproject`.`users`;";
        reader = cmd.ExecuteReader();

        while (reader.Read())
        {
            if (reader["userEmail"].ToString() == email)
            {
                reader.Close();
                return false;
            }
        }

        reader.Close();
        return true;
    }

    void AddUser()
    {   
        if (!int.TryParse(birthYear, out _))
        {
            title = "Invalid birth year";
        } // Negative year and year in future will fail the registration
        else if (int.Parse(birthYear) < 0 || DateTime.Now.Year - int.Parse(birthYear) < 0) 
        {
            title = "Invalid birth year";
        }
        else if (!IsEmailUnique())
        {
            title = "User with that email already exists";
        }
        else
        {
            cmd.CommandText = $"INSERT INTO `classproject`.`users` (`userPassword`, `userName`, `userEmail`, `birthYear`) VALUES ('{password}', '{name}', '{email}', '{int.Parse(birthYear)}');";
            registered = cmd.ExecuteNonQuery() > 0;
            title = registered ? "Registered!" : "Registration failed";
            
            cmd.CommandText = $"SELECT * FROM `classproject`.`users`;";
            reader = cmd.ExecuteReader();
            while (reader.Read())
            {
                id = uint.Parse(reader["userID"].ToString());
            }
            reader.Close();
            
            CypherData();
        }
    }

    void CypherData()
    {
        cypheredEmail = Cypher.ShiftCypher(email, int.Parse(birthYear));
        cypheredPass = Cypher.ShiftCypher(password, int.Parse(birthYear));
    }
}
